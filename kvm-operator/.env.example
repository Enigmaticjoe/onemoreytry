# ─────────────────────────────────────────────────────────────────────────────
# AI KVM Operator — Environment Variables
# Copy this file to .env and fill in your values before running run_dev.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Operator Auth ────────────────────────────────────────────────────────────
# Secret Bearer token that clients must present to use this API.
# Generate: openssl rand -hex 24
KVM_OPERATOR_TOKEN=change-me-use-openssl-rand-hex-24

# ── NanoKVM Credentials ──────────────────────────────────────────────────────
# Default credentials shared by all targets (override per-target via KVM_TARGETS_JSON).
NANOKVM_USERNAME=admin
NANOKVM_PASSWORD=admin

# Auth mode: auto (try encrypted first, then plain), encrypted, or plain
NANOKVM_AUTH_MODE=auto

# Optional: override the AES-256-CBC key used to encrypt the login password.
# Default is the firmware's hardcoded key (see GitHub Issue #270).
# NANOKVM_SECRET_KEY=nanokvm-sipeed-2024

# ── KVM Targets ──────────────────────────────────────────────────────────────
# JSON map of logical name → IP address.
# Example — single target:
KVM_TARGETS_JSON={"node-c":"192.168.1.100"}
# Example — multiple targets:
# KVM_TARGETS_JSON={"node-c":"192.168.1.100","node-e":"192.168.1.101"}

# ── LiteLLM Vision (for /kvm/task vision-loop endpoint) ─────────────────────
LITELLM_URL=http://192.168.1.222:4000/v1/chat/completions
LITELLM_KEY=sk-master-key
VISION_MODEL=intel-vision

# ── Safety ───────────────────────────────────────────────────────────────────
# REQUIRE_APPROVAL=true  → write endpoints return HTTP 202 (human-in-the-loop)
# REQUIRE_APPROVAL=false → write endpoints execute immediately (headless mode)
REQUIRE_APPROVAL=true

# Allow commands matched by policy_denylist.txt (mkfs, dd, rm -rf, etc.).
# NEVER set true in production.
ALLOW_DANGEROUS=false

# Maximum vision-loop steps before aborting (/kvm/task)
MAX_STEPS_DEFAULT=10

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
