# Copy to .env and update.
# KVM operator should run on Node A (Brain), default port 5000.

KVM_OPERATOR_TOKEN=change-me-use-openssl-rand-hex-24
REQUIRE_APPROVAL=true
ALLOW_DANGEROUS=false

# Node map (target name -> NanoKVM IP)
# NanoKVM device: kvm-d829.local at 192.168.1.130
KVM_TARGETS_JSON={"kvm-d829":"192.168.1.130"}
NANOKVM_USERNAME=admin
NANOKVM_PASSWORD=admin

# Auth mode: auto (try encrypted then plain), encrypted, or plain
NANOKVM_AUTH_MODE=auto

# Session TTL in seconds (sessions are cached to avoid re-login on every request)
SESSION_TTL=300

# Route model-assisted operations via LiteLLM
# Both LITELLM_KEY and LITELLM_API_KEY are accepted for compatibility
LITELLM_URL=http://192.168.1.222:4000/v1/chat/completions
LITELLM_API_KEY=sk-master-key
VISION_MODEL=kvm-vision

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
