# Node A — vLLM environment variables
# Copy this file to .env and set real values before deploying.

# HuggingFace token — required for gated models such as Llama-3.
# Generate one at https://huggingface.co/settings/tokens (read access is enough).
HUGGINGFACE_TOKEN=hf_your_token_here

# Model to serve.  Start with an 8B or 14B model to validate VRAM and latency
# before promoting to a larger model.
#
# Tested options for RX 7900 XT (20 GB VRAM):
#   meta-llama/Llama-3.1-8B-Instruct   ~18 GB  (fp16, fits comfortably)
#   meta-llama/Llama-3.1-14B-Instruct  ~28 GB  (requires quantization — use Q4)
#   mistralai/Mistral-7B-Instruct-v0.3 ~15 GB  (fp16, fits comfortably)
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
