# Brain Project — Node A environment variables
# Copy this file to .env and fill in real values before running setup.sh.
#
# Hardware: AMD Radeon RX 7900 XT (20GB) | Intel i9-265F | 128GB RAM
# Model:    Dolphin 2.9.3 Llama 3.1 8B AWQ (cognitivecomputations/dolphin-2.9.3-llama-3.1-8b-AWQ)

###############################################################################
# Required — set these before first deployment
###############################################################################

# HuggingFace token — required to download the Dolphin model weights.
# Generate one at https://huggingface.co/settings/tokens (read access is enough).
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Secret key for OpenWebUI session signing — use a long random string.
# Generate: openssl rand -hex 32
WEBUI_SECRET_KEY=change_me_to_a_random_secret

# Secret key for SearXNG request signing — use a long random string.
# Generate: openssl rand -hex 32
SEARXNG_SECRET=change_me_to_a_random_secret

###############################################################################
# Optional — sensible defaults are provided
###############################################################################

# OpenAI-compatible API key sent to vLLM (any non-empty string works locally).
OPENAI_API_KEY=sk-brain-local

# Qdrant API key — leave blank to run Qdrant without authentication.
QDRANT_API_KEY=

# JupyterLab access token for the Coding Agent notebook.
# Set to a strong password or leave as default for local-only access.
JUPYTER_TOKEN=brain-notebook

# GIDs for GPU device access in containers (auto-detected by setup.sh).
# Docker resolves group_add entries by name inside the container, which fails
# for distro-specific groups like 'render'.  Using numeric GIDs bypasses that
# lookup.  Find your values with: getent group render | cut -d: -f3
RENDER_GID=989
VIDEO_GID=44
