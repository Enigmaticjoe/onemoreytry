// OpenClaw Configuration — Unraid Setup
// Format: JSON5 (comments + trailing commas are allowed)
// Path:   /mnt/user/appdata/openclaw/config/openclaw.json
//
// CRITICAL: Unknown top-level keys crash the Gateway on startup.
//           Only use keys documented here.
//
// Before first deploy:
//   1. Set your vLLM model ID (check: curl http://<UNRAID_IP>:8880/v1/models | jq '.data[].id')
//   2. Set contextWindow to match your vLLM --max-model-len value
//   3. Remove any providers/tools you don't use
//
// Hot-reload: most changes apply without restart.
// Exception: gateway.* settings require a container restart.
{
  // ── Default Model Selection ────────────────────────────────────────────
  // Format: "providerName/model-id"
  // Switch live (no restart): /model vllm/your-model-id
  // List all available:       node dist/index.js models list
  agents: {
    defaults: {
      model: {
        // LOCAL FIRST — your hf-vllm on port 8880
        // Change "your-model-id-here" to the actual model ID vLLM is serving
        primary: "vllm/your-model-id-here",

        // CLOUD FALLBACKS — used if vLLM is unavailable or rate-limited
        // Remove any you don't have API keys for
        fallbacks: [
          "anthropic/claude-sonnet-4-6",
          "openai/gpt-4o-mini",
          "google/gemini-2.0-flash",
          "openrouter/google/gemini-2.0-flash-exp:free",
        ],
      },

      // Run agent code execution in isolated Docker containers
      sandbox: {
        mode: "non-main",
      },
    },
  },

  // ── Custom Model Providers ─────────────────────────────────────────────
  // Built-in providers (anthropic, openai, google, openrouter, xai, groq,
  // mistral, cerebras, ollama, huggingface, github-copilot) are auto-
  // configured from their env vars — no entry needed here for those.
  //
  // Add an entry ONLY for local/custom inference servers with non-default URLs.
  models: {
    providers: {
      // ── vLLM (your hf-vllm container on port 8880) ──────────────────
      // VLLM_API_KEY env var must be set (any value) for this to activate.
      // Because we use a non-default baseUrl, we define it explicitly here
      // (auto-discovery only works for 127.0.0.1:8000).
      vllm: {
        baseUrl: "http://host.docker.internal:8880/v1",
        // ${...} resolves from environment — matches VLLM_API_KEY in compose
        apiKey: "${VLLM_API_KEY}",
        api: "openai-completions",
        models: [
          {
            // CHANGE THIS to your actual model ID from: GET /v1/models
            id: "your-model-id-here",
            name: "Local vLLM",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            // Match to your vLLM --max-model-len launch parameter
            contextWindow: 32768,
            maxTokens: 8192,
          },
          // Add more if vLLM serves multiple models:
          // {
          //   id: "second-model-id",
          //   name: "Second Model",
          //   contextWindow: 128000,
          //   maxTokens: 16384,
          // },
        ],
      },

      // ── HuggingFace TEI (your hf-tei-embed on port 8881) ────────────
      // Your hf-tei-embed container serves text embeddings. OpenClaw can
      // use it for semantic search / memory. Configured separately from
      // the huggingface chat provider (set HF_TOKEN env var for that).
      // No entry needed here — configure TEI via your memory/rag settings.

    },
  },

  // ── Tools ──────────────────────────────────────────────────────────────
  tools: {
    // ── Local Search (your hf-searxng on port 8082) ──────────────────
    // Agents use this for web search without needing a Brave/Perplexity key.
    searxng: {
      baseUrl: "http://host.docker.internal:8082",
      enabled: true,
    },

    // ── Browser Automation ────────────────────────────────────────────
    // Option A (default): dedicated openclaw-browser container in this stack
    browser: {
      wsEndpoint: "ws://openclaw-browser:3000",
    },
    // Option B: reuse your existing browserless on port 3005
    // Comment out Option A above and uncomment this:
    // browser: {
    //   wsEndpoint: "ws://host.docker.internal:3005",
    // },
  },

  // ── Gateway Settings ───────────────────────────────────────────────────
  gateway: {
    bind: "lan",
    port: 18789,

    auth: {
      // Token is read from OPENCLAW_GATEWAY_TOKEN env var automatically.
      // Do not hardcode the token here.
      mode: "token",
    },

    // ── OpenAI-Compatible HTTP API ──────────────────────────────────
    // Enables POST /v1/chat/completions on port 18789.
    // This lets Open WebUI (your hf-openwebui on :3002) connect to OpenClaw
    // as a backend — point it at http://<UNRAID_IP>:18789/v1
    // Auth: Authorization: Bearer <OPENCLAW_GATEWAY_TOKEN>
    // Select agent: model field = "openclaw:main" or "agent:main"
    http: {
      endpoints: {
        chatCompletions: { enabled: true },
        // Also enable OpenResponses API (supports images, files, streaming):
        responses: { enabled: true },
      },
    },

    // ── Webhook Endpoints ────────────────────────────────────────────
    // POST /hooks/agent — trigger an agent turn programmatically
    // POST /hooks/wake  — send a system event
    // Auth: Authorization: Bearer <OPENCLAW_GATEWAY_TOKEN>
    //
    // Use these to automate OpenClaw from:
    //   • Home Assistant automations
    //   • Unraid User Scripts plugin
    //   • n8n / any HTTP client
    //
    // Example — query Unraid and get AI response via User Script:
    //   curl -s -X POST http://localhost:18790/hooks/agent \
    //     -H "Authorization: Bearer $OPENCLAW_GATEWAY_TOKEN" \
    //     -H "Content-Type: application/json" \
    //     -d '{"message":"Check my array health and summarize disk temps"}'
    hooks: {
      enabled: true,
      // Matches OPENCLAW_GATEWAY_TOKEN — do not hardcode here
      token: "${OPENCLAW_GATEWAY_TOKEN}",
      path: "/hooks",
    },

    // ── Web Control UI ───────────────────────────────────────────────
    // Enables a browser dashboard at http://<UNRAID_IP>:18790
    controlUi: {
      enabled: true,
    },
  },

  // ── Skills ─────────────────────────────────────────────────────────────
  // Skills are SKILL.md files that give agents new capabilities.
  // Browse skills at: https://clawhub.com
  // Install with: node dist/index.js skills install <skill-name>
  //
  // Unraid control skill (if published to ClawHub — check the registry):
  // skills: {
  //   entries: {
  //     "unraid": { enabled: true }
  //   }
  // },
}
