# Fresh Rebuild 2026 — Node B Environment Template
# Unraid · RTX 4070 · 192.168.1.222
#
# Copy to .env before deploying:
#   cp node-b/.env.example node-b/.env
#
# NEVER commit node-b/.env — it is excluded by .gitignore.

# ─── Common ───────────────────────────────────────────────────────────────────
TZ=America/New_York

# Unraid Portainer container permissions (nobody:users)
PUID=99
PGID=100

# Node B LAN IP (used by n8n webhook URLs)
NODE_B_IP=192.168.1.222

# Base path for all persistent container config on Unraid
APPDATA_PATH=/mnt/user/appdata

# ─── Homepage ─────────────────────────────────────────────────────────────────
# Home Assistant long-lived access token for the HA widget on the dashboard.
# Generate in HA → Profile → Security → Long-Lived Access Tokens.
HA_TOKEN=your-ha-long-lived-token-here

# ─── Watchtower notifications (optional) ─────────────────────────────────────
# Discord webhook URL for container update notifications.
# Format: discord://webhook-id/webhook-token
# Leave blank to disable Discord notifications.
WATCHTOWER_DISCORD_URL=

# ─── n8n ──────────────────────────────────────────────────────────────────────
# n8n admin credentials for the web UI.
N8N_USER=admin
# REQUIRED — generate a strong password: openssl rand -base64 24
N8N_PASSWORD=CHANGE_ME_INSECURE
