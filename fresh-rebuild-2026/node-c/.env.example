# Fresh Rebuild 2026 — Node C Environment Template
# Fedora 44 · Intel Arc A770 · 192.168.1.6
#
# Copy to .env before deploying:
#   cp node-c/.env.example node-c/.env
#
# NEVER commit node-c/.env — it is excluded by .gitignore.

# ─── Common ───────────────────────────────────────────────────────────────────
TZ=America/New_York

# Path on the Fedora host for Open WebUI persistent data.
APPDATA_PATH=/opt/open-webui

# ─── Open WebUI ───────────────────────────────────────────────────────────────
# Web UI display name shown in the browser tab and login page.
WEBUI_NAME=Home Lab AI

# Secret key for session signing and encryption.
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME_INSECURE

# Semicolon-separated list of Ollama backend URLs.
# Order matters: first URL is the default for new chats.
# Node A ROCm (:11435) handles heavy models; Node B CUDA (:11434) for fast tasks.
OLLAMA_BASE_URLS=http://192.168.1.9:11435;http://192.168.1.222:11434
