# Fresh Rebuild 2026 — Node A Environment Template
# Fedora 44 · RX 7900 XT · 192.168.1.9
#
# Copy to .env before deploying:
#   cp node-a/.env.example node-a/.env
#
# NEVER commit node-a/.env — it is excluded by .gitignore.

# ─── Common ───────────────────────────────────────────────────────────────────
TZ=America/New_York

# Path on the Fedora host where Ollama model files are stored.
# The default /opt/ollama is fine for a dedicated drive; adjust as needed.
APPDATA_PATH=/opt/ollama
