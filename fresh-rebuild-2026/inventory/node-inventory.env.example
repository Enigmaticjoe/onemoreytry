# Fresh Rebuild 2026 — Node Inventory Template
# Copy this file to node-inventory.env and fill in your values.
#
#   cp inventory/node-inventory.env.example inventory/node-inventory.env
#
# This file is sourced by preflight.sh, deploy-all.sh, and the per-node scripts.
# NEVER commit node-inventory.env — it is excluded by .gitignore.

# ─── LAN IPs ──────────────────────────────────────────────────────────────────
NODE_A_IP=192.168.1.9
NODE_B_IP=192.168.1.222
NODE_C_IP=192.168.1.6
NODE_D_IP=192.168.1.149
NODE_E_IP=192.168.1.116

# ─── SSH users ────────────────────────────────────────────────────────────────
NODE_A_SSH_USER=your-fedora-username
NODE_B_SSH_USER=root
NODE_C_SSH_USER=your-fedora-username

# ─── Tailscale IPs (preferred over LAN for remote operations) ─────────────────
# Leave blank to fall back to LAN IPs above.
NODE_A_TS_IP=
NODE_B_TS_IP=
NODE_C_TS_IP=

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=America/New_York
