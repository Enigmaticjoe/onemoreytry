# =============================================================================
# Project Chimera — new-system master environment template
# Node B · Unraid · 192.168.1.222 · RTX 4070 · 96 GB DDR5
# =============================================================================
# Copy to .env before deploying ANY stack:
#   cp .env.example .env
#
# Generate secure tokens:
#   openssl rand -hex 32       (for API keys, secrets)
#   openssl rand -hex 16       (for shorter tokens)
#
# NEVER commit .env — it is excluded by .gitignore.
# =============================================================================

# ─── Common ───────────────────────────────────────────────────────────────────
TZ=America/New_York

# Unraid nobody:users — REQUIRED for correct file ownership on Unraid
PUID=99
PGID=100

# Node IPs — matches canonical architecture
NODE_B_IP=192.168.1.222
NODE_A_IP=192.168.1.9
NODE_C_IP=192.168.1.6
HA_IP=192.168.1.149

# ─── DUMB AIO Paths ───────────────────────────────────────────────────────────
# All container config lives under /mnt/user/appdata/DUMB/<service>
APPDATA_PATH=/mnt/user/appdata/DUMB
# All media files live under /mnt/user/DUMB/
MEDIA_PATH=/mnt/user/DUMB
# rclone FUSE mounts Zurg (Real-Debrid) here — must be pre-configured rshared
DEBRID_MOUNT=/mnt/debrid
# Riven writes symlinks here — Plex/Jellyfin point ONLY at this path
RIVEN_SYMLINKS=/mnt/debrid/riven_symlinks

# ─── Stack 01 — Infrastructure ────────────────────────────────────────────────
# Homepage Home Assistant widget token
# HA → Profile → Security → Long-Lived Access Tokens
HA_TOKEN=your-ha-long-lived-access-token

# Tailscale auth key — generate at https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXX

# Cloudflare Zero Trust tunnel token
# dash.cloudflare.com → Zero Trust → Networks → Tunnels → Create tunnel
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Watchtower — Discord webhook for update notifications (optional)
# Format: discord://webhook-id/webhook-token
WATCHTOWER_DISCORD_URL=

# ─── Stack 02 — AI Core ───────────────────────────────────────────────────────
# n8n admin credentials
N8N_USER=admin
# REQUIRED: openssl rand -base64 24
N8N_PASSWORD=CHANGE_ME_INSECURE

# Open WebUI session secret: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=CHANGE_ME_INSECURE

# SearXNG secret key: openssl rand -hex 32
SEARXNG_SECRET_KEY=CHANGE_ME_INSECURE

# Whisper model (large-v3 recommended for GPU; small-int8 for CPU-only)
WHISPER_MODEL=large-v3

# Wyoming Whisper model for HA voice pipeline (small-int8 is faster here)
WYOMING_WHISPER_MODEL=small-int8

# Wyoming Piper TTS voice
# Options: en_US-lessac-medium, en_US-ryan-high, en_GB-alan-medium
PIPER_VOICE=en_US-lessac-medium

# Media service API keys — retrieve from each app's Settings → API page
# Fill in AFTER each service starts for the first time
OVERSEERR_API_KEY=your-overseerr-api-key
RADARR_API_KEY=your-radarr-api-key
SONARR_API_KEY=your-sonarr-api-key
READARR_API_KEY=your-readarr-api-key
LIDARR_API_KEY=your-lidarr-api-key
RIVEN_API_KEY=your-riven-api-key

# ─── Stack 03 — DUMB Core (Real-Debrid / Riven) ───────────────────────────────
# Real-Debrid API token — https://real-debrid.com/apitoken
REAL_DEBRID_API_KEY=your-real-debrid-api-key

# Riven database — CHANGE BOTH values before first deploy
# openssl rand -base64 24
RIVEN_DB_PASSWORD=CHANGE_ME_INSECURE
RIVEN_DB_USER=riven
RIVEN_DB_NAME=riven

# Riven frontend session secret: openssl rand -base64 32
RIVEN_AUTH_SECRET=CHANGE_ME_INSECURE

# Riven VFS shared memory (reduce to 512m if RAM is constrained)
RIVEN_SHM_SIZE=1024m

# Plex token (for Riven ↔ Plex sync) — see https://support.plex.tv/articles/204059436/
PLEX_TOKEN=your-plex-token
# Claim token for FIRST Plex setup only — https://www.plex.tv/claim/
PLEX_CLAIM_TOKEN=claim-your-token-here

# Zilean — optional API key to restrict access (leave blank to disable auth)
ZILEAN_API_KEY=

# ─── Stack 04 — Media *arr ────────────────────────────────────────────────────
# VPN for download traffic (Gluetun)
# Provider: private internet access, mullvad, nordvpn, expressvpn, surfshark...
VPN_SERVICE_PROVIDER=private internet access
VPN_USER=your-vpn-username
VPN_PASSWORD=your-vpn-password
VPN_REGIONS=US East

# Bazarr — Whisper API for AI subtitle generation
# Points to whisper-api container on Stack 02
BAZARR_WHISPER_URL=http://whisper-api:8000

# ─── Stack 05 — Media Servers ─────────────────────────────────────────────────
# Jellyfin API key — Jellyfin → Dashboard → API Keys → +
# Fill in AFTER Jellyfin first run
JELLYFIN_API_KEY=your-jellyfin-api-key

# Last.fm API keys for Navidrome (music scrobbling + artist art)
# https://www.last.fm/api/account/create
LASTFM_API_KEY=
LASTFM_SECRET=

# Spotify (for Navidrome album art fetching)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─── Stack 06 — Books & Games ─────────────────────────────────────────────────
# RAWG API key for GameVault metadata — https://rawg.io/apidocs
RAWG_API_KEY=your-rawg-api-key

# GameVault admin credentials
GAMEVAULT_ADMIN_USER=admin
# openssl rand -base64 16
GAMEVAULT_ADMIN_PASSWORD=CHANGE_ME_INSECURE
GAMEVAULT_DB_PASSWORD=CHANGE_ME_INSECURE

# Romm secrets
# IGDB — Twitch dev app: https://dev.twitch.tv/console
IGDB_CLIENT_ID=your-igdb-client-id
IGDB_CLIENT_SECRET=your-igdb-client-secret
# SteamGridDB — https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=
# openssl rand -hex 32
ROMM_SECRET_KEY=CHANGE_ME_INSECURE
ROMM_DB_PASSWORD=CHANGE_ME_INSECURE

# ─── Stack 07 — Media Management ──────────────────────────────────────────────
# Tautulli API key — Tautulli → Settings → Web Interface → API key
TAUTULLI_API_KEY=your-tautulli-api-key

# Notifiarr API key — https://notifiarr.com (free tier available)
NOTIFIARR_API_KEY=your-notifiarr-api-key

# Kometa (Plex Meta Manager) — connects to Plex
# PLEX_TOKEN is shared from Stack 03 section above

# Maintainerr — connects to Plex, Sonarr, Radarr (configured in UI, no extra secrets)

# Recyclarr — Sonarr and Radarr API keys shared from Stack 04 section above
