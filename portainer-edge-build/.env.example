# Copy to .env and fill values before deployment

# ===== Portainer Business Edition =====
PORTAINER_LICENSE_KEY=replace-with-your-portainer-be-license
PORTAINER_ADMIN_EMAIL=admin@example.local

# ===== Central Portainer host (Node B suggested) =====
PORTAINER_HOST_IP=192.168.1.222

# ===== Edge IDs and Keys (generated in Portainer UI) =====
# Add each edge endpoint in Portainer first, then paste values here.
NODE_A_EDGE_ID=replace_node_a_edge_id
NODE_A_EDGE_KEY=replace_node_a_edge_key

NODE_B_EDGE_ID=replace_node_b_edge_id
NODE_B_EDGE_KEY=replace_node_b_edge_key

NODE_C_EDGE_ID=replace_node_c_edge_id
NODE_C_EDGE_KEY=replace_node_c_edge_key

# ===== Optional SSH deploy settings =====
NODE_A_IP=192.168.1.9
NODE_B_IP=192.168.1.222
NODE_C_IP=192.168.1.6
SSH_USER=root
