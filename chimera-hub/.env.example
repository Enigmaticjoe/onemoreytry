# Chimera Hub runtime
PUID=99
PGID=100
PORT=3099
TZ=America/New_York
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000
PORTAINER_ENDPOINT_ID=3
JWT_SECRET=change-me-to-a-long-random-secret
CHIMERA_HUB_ADMIN_PASSWORD=change-me-now
CHIMERA_HUB_AUTH_FILE=/app/data/auth.json

# Infrastructure endpoints
PORTAINER_URL=http://192.168.1.222:9000
PORTAINER_TOKEN=replace-with-portainer-api-key
LITELLM_BASE_URL=http://192.168.1.222:4000
LITELLM_API_KEY=replace-with-litellm-key
OPENCLAW_RELAY_URL=http://192.168.1.222:18790
KVM_OPERATOR_URL=http://192.168.1.9:5000
KVM_OPERATOR_TOKEN=replace-with-kvm-operator-token
HOME_ASSISTANT_URL=http://192.168.1.149:8123
HOME_ASSISTANT_TOKEN=replace-with-home-assistant-token
BROTHERS_KEEPER_URL=http://192.168.1.9:7070
UPTIME_KUMA_URL=http://192.168.1.222:3010
UPTIME_KUMA_API_KEY=
DOZZLE_URL=http://192.168.1.222:8888
QDRANT_URL=http://192.168.1.9:6333
CHIMERA_NODE_INVENTORY=/app/data/node-inventory.env
KVM_DENYLIST_PATH=/app/data/policy_denylist.txt
