# =============================================================================
# NanoClaw + UnraidClaw Environment Template — Unraid Node B (192.168.1.222)
# =============================================================================
# Copy to /mnt/user/appdata/nanoclaw/.env and fill all REPLACE_ME / GENERATE_ME
# placeholders before first deploy.
#
# deploy.sh will prompt for critical values interactively if .env doesn't exist.
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime identity
# -----------------------------------------------------------------------------
TZ=America/New_York
PUID=99
PGID=100
NODE_ENV=production

# Docker socket group GID on host (run: stat -c '%g' /var/run/docker.sock)
# Override if your host's docker group is not GID 999.
DOCKER_GID=999

# -----------------------------------------------------------------------------
# LLM provider routing
# -----------------------------------------------------------------------------
# Primary endpoint — local Ollama on Node B (RTX 4070 12GB).
# NanoClaw uses ANTHROPIC_BASE_URL/ANTHROPIC_AUTH_TOKEN for its provider config.
ANTHROPIC_BASE_URL=http://192.168.1.222:11434/v1
ANTHROPIC_AUTH_TOKEN=ollama

# Model selection by task complexity (consumed by model-router sidecar).
DEFAULT_AGENT_MODEL=qwen3:14b-abliterated
FAST_AGENT_MODEL=glm4-flash-heretic
FALLBACK_AGENT_MODEL=josiefied-qwen3:8b

# Complex reasoning — routed to Node A vLLM (AMD RX 7900 XT 20GB, ROCm).
# Replace NODE_A_TAILSCALE with the actual Tailscale IP of Node A.
COMPLEX_AGENT_BASE_URL=http://NODE_A_TAILSCALE:8000/v1
COMPLEX_AGENT_MODEL=qwen3-14b-awq

# -----------------------------------------------------------------------------
# Messaging integrations (leave empty to disable a channel)
# -----------------------------------------------------------------------------
# Discord: Create bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=REPLACE_ME
DISCORD_WEBHOOK_URL=

# Telegram: Create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# Slack: Create app at https://api.slack.com/apps (Bot Token scope: chat:write)
SLACK_BOT_TOKEN=

# WhatsApp: Meta Business API access token
WHATSAPP_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# MCP server credentials (used in .mcp.json via ${VAR} substitution)
# -----------------------------------------------------------------------------
# UnraidClaw — generate key: openssl rand -hex 32
# Option A (plugin): configure in Unraid WebGUI, copy key here.
# Option B (container): deploy.sh generates key and self-signed cert.
UNRAIDCLAW_URL=https://192.168.1.222:9876
UNRAIDCLAW_API_KEY=GENERATE_ME
UNRAID_GRAPHQL_URL=https://192.168.1.222/graphql

# Home Assistant — generate Long-Lived Access Token in HA Profile page.
# Node D is at 192.168.1.149 per architecture doc.
HOME_ASSISTANT_URL=http://192.168.1.149:8123
HOME_ASSISTANT_TOKEN=REPLACE_ME

# GitHub — Personal Access Token (fine-grained, repo scope for Enigmaticjoe/onemoreytry)
GITHUB_TOKEN=REPLACE_ME

# Web search — at least one recommended. Brave preferred, Tavily as fallback.
BRAVE_API_KEY=REPLACE_ME
TAVILY_API_KEY=

# Qdrant vector DB on Node A — for RAG corpus search.
# Replace NODE_A_TAILSCALE with actual Tailscale IP.
QDRANT_URL=http://NODE_A_TAILSCALE:6333
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
# Health check / monitoring
# -----------------------------------------------------------------------------
NANOCLAW_HEALTH_PORT=3000
OLLAMA_HEALTH_URL=http://192.168.1.222:11434/api/tags
UNRAIDCLAW_HEALTH_URL=https://192.168.1.222:9876/health
