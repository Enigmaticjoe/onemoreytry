# NanoClaw/UnraidClaw environment template for Unraid Node B.
# Copy to /mnt/user/appdata/nanoclaw/.env and fill placeholders.

##############################
# Core runtime identity
##############################
TZ=America/New_York
PUID=99
PGID=100
NODE_ENV=production

##############################
# LLM provider routing
##############################
# Primary endpoint (local Ollama on Node B)
ANTHROPIC_BASE_URL=http://192.168.1.222:11434/v1
ANTHROPIC_AUTH_TOKEN=ollama

# Model routing hints used by router.py / scripts
DEFAULT_AGENT_MODEL=qwen3:14b-abliterated
FAST_AGENT_MODEL=glm4-flash-heretic
COMPLEX_AGENT_BASE_URL=http://NODE_A_TAILSCALE:8000/v1
COMPLEX_AGENT_MODEL=qwen3-14b-awq
FALLBACK_AGENT_MODEL=josiefied-qwen3:8b

##############################
# Messaging integrations
##############################
DISCORD_BOT_TOKEN=REPLACE_ME
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME
SLACK_BOT_TOKEN=
WHATSAPP_ACCESS_TOKEN=

##############################
# MCP / external tools
##############################
UNRAIDCLAW_URL=https://192.168.1.222:9876
UNRAIDCLAW_API_KEY=GENERATE_ME
