# Node A — Command Center environment variables
# Copy this file to .env and set real values before starting the dashboard.

# Port the dashboard listens on (default: 3099)
COMMAND_CENTER_PORT=3099

# LiteLLM gateway on Node B
LITELLM_BASE_URL=http://192.168.1.222:4000
LITELLM_API_KEY=sk-master-key

# Default AI model (must be registered in LiteLLM config.yaml)
DEFAULT_MODEL=brain-heavy

# vLLM / Ollama on Node A itself
BRAIN_BASE_URL=http://192.168.1.9:8000

# Ollama on Node C (Intel Arc)
NODE_C_BASE_URL=http://192.168.1.6

# Home Assistant on Node D
NODE_D_BASE_URL=http://192.168.1.149:8123

# Sentinel / Frigate on Node E
NODE_E_BASE_URL=http://192.168.1.116:3005

# Monitoring / infra services on Node B (Unraid)
UPTIME_KUMA_BASE_URL=http://192.168.1.222:3010
DOZZLE_BASE_URL=http://192.168.1.222:8888
HOMEPAGE_BASE_URL=http://192.168.1.222:8010
