#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════════════════════
# Agent Instruction Framework — Pre-commit Hook
# Grand Unified AI Home Lab / Project Chimera
#
# Runs automatically when `git commit` is invoked.
# Install: cp agent-governance/hooks/pre-commit .git/hooks/pre-commit
#          chmod +x .git/hooks/pre-commit
# Or use the pre-commit framework: pre-commit install
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
HOOK_DIR="$(dirname "$(realpath "$0")")"
DESTRUCTIVE_CHECK="${HOOK_DIR}/destructive-check.sh"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

pass() { echo -e "${GREEN}[pre-commit] ✓ $*${NC}"; }
warn() { echo -e "${YELLOW}[pre-commit] ⚠ $*${NC}"; }
fail() { echo -e "${RED}[pre-commit] ✗ $*${NC}"; exit 1; }

echo "[pre-commit] Running Agent Instruction Framework hooks..."

# ─────────────────────────────────────────────────────────────────────────────
# 1. Destructive change detection
# ─────────────────────────────────────────────────────────────────────────────
if [ -x "$DESTRUCTIVE_CHECK" ]; then
    "$DESTRUCTIVE_CHECK" || fail "Destructive change detection blocked the commit."
    pass "Destructive change detection"
else
    warn "destructive-check.sh not found or not executable; skipping"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 2. YAML syntax check (all staged .yml / .yaml files)
# ─────────────────────────────────────────────────────────────────────────────
STAGED_YAML=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(yml|yaml)$' || true)
if [ -n "$STAGED_YAML" ]; then
    if command -v python3 >/dev/null 2>&1; then
        while IFS= read -r f; do
            python3 -c "import yaml, sys; yaml.safe_load(open('${REPO_ROOT}/${f}'))" \
                2>/dev/null || fail "YAML syntax error in ${f}"
        done <<< "$STAGED_YAML"
        pass "YAML syntax check"
    else
        warn "python3 not available; skipping YAML syntax check"
    fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# 3. Shell script syntax check (all staged .sh files)
# ─────────────────────────────────────────────────────────────────────────────
STAGED_SH=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.sh$' || true)
if [ -n "$STAGED_SH" ]; then
    while IFS= read -r f; do
        bash -n "${REPO_ROOT}/${f}" 2>/dev/null || fail "Shell syntax error in ${f}"
    done <<< "$STAGED_SH"
    pass "Shell syntax check"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 4. Python linting (staged .py files via ruff if available)
# ─────────────────────────────────────────────────────────────────────────────
# Use a mapfile/array to handle file paths with spaces correctly
STAGED_PY=()
while IFS= read -r f; do
    STAGED_PY+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [ "${#STAGED_PY[@]}" -gt 0 ]; then
    if command -v ruff >/dev/null 2>&1; then
        ruff check --select E,F,W,I --ignore S603,S607 "${STAGED_PY[@]}" \
            2>/dev/null || fail "ruff linting failed. Run: ruff check --fix"
        pass "Python linting (ruff)"
    elif command -v flake8 >/dev/null 2>&1; then
        flake8 "${STAGED_PY[@]}" 2>/dev/null || fail "flake8 linting failed."
        pass "Python linting (flake8)"
    else
        warn "Neither ruff nor flake8 found; skipping Python linting"
    fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# 5. Security scan (staged .py files via bandit if available)
# ─────────────────────────────────────────────────────────────────────────────
if [ "${#STAGED_PY[@]}" -gt 0 ]; then
    if command -v bandit >/dev/null 2>&1; then
        bandit -ll --skip B101,B603,B607 -q "${STAGED_PY[@]}" \
            2>/dev/null || fail "bandit security scan failed. Review the findings above."
        pass "Security scan (bandit)"
    else
        warn "bandit not found; skipping security scan (install with: pip install bandit)"
    fi
fi

# ─────────────────────────────────────────────────────────────────────────────
# 6. Secrets detection (crude but fast; does not replace a dedicated tool)
# ─────────────────────────────────────────────────────────────────────────────
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED_ALL" ]; then
    SECRET_PATTERNS=(
        'password\s*=\s*['"'"'"][^'"'"'"]{8,}'
        'api_key\s*=\s*['"'"'"][^'"'"'"]{8,}'
        'secret\s*=\s*['"'"'"][^'"'"'"]{16,}'
        'PRIVATE KEY'
        'BEGIN RSA PRIVATE KEY'
    )
    for f in $STAGED_ALL; do
        FULL="${REPO_ROOT}/${f}"
        [ -f "$FULL" ] || continue
        # Skip .env.example and .gitignore
        [[ "$f" == *".env.example" ]] && continue
        [[ "$f" == *".gitignore" ]] && continue
        for pattern in "${SECRET_PATTERNS[@]}"; do
            if grep -qiE "$pattern" "$FULL" 2>/dev/null; then
                fail "Potential secret detected in ${f}. Pattern: ${pattern}"
            fi
        done
    done
    pass "Secrets detection"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 7. Policy validation (agent-config.yml must be valid YAML if staged)
# ─────────────────────────────────────────────────────────────────────────────
if echo "$STAGED_ALL" | grep -q "agent-governance/agent-config.yml"; then
    python3 -c "
import yaml, sys
try:
    data = yaml.safe_load(open('${REPO_ROOT}/agent-governance/agent-config.yml'))
    required = ['schema_version', 'execution_modes', 'roles', 'quality_gates', 'hard_blocks']
    missing = [k for k in required if k not in data]
    if missing:
        print('agent-config.yml missing required keys: ' + ', '.join(missing))
        sys.exit(1)
except Exception as e:
    print(f'agent-config.yml parse error: {e}')
    sys.exit(1)
" || fail "Policy validation of agent-config.yml failed"
    pass "Policy validation"
fi

# ─────────────────────────────────────────────────────────────────────────────
# 8. Agent activity log (append to log file if AGENT_ID is set)
# ─────────────────────────────────────────────────────────────────────────────
if [ -n "${AGENT_ID:-}" ]; then
    LOG_DIR="/var/log/agent-governance"
    LOG_FILE="${LOG_DIR}/activity.jsonl"
    if [ -d "$LOG_DIR" ] || mkdir -p "$LOG_DIR" 2>/dev/null; then
        TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        CHANGED_FILES=$(git diff --cached --name-only | tr '\n' ',' | sed 's/,$//')
        printf '{"timestamp":"%s","agent_id":"%s","action":"pre_commit","files":"%s"}\n' \
            "$TIMESTAMP" "${AGENT_ID}" "$CHANGED_FILES" >> "$LOG_FILE" 2>/dev/null || true
    fi
fi

echo "[pre-commit] All hooks passed."
