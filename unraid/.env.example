# Unraid Management Stack - Environment Variables
# Copy to .env and fill in values before deploying

# Tailscale auth key (generate at https://login.tailscale.com/admin/authkeys)
TAILSCALE_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXX

# Subnet to advertise via Tailscale exit node (e.g. your LAN CIDR)
LOCAL_SUBNET=192.168.1.0/24

# Base path for persistent container appdata on Unraid
APPDATA_PATH=/mnt/user/appdata

# Timezone (e.g. America/Chicago)
TZ=America/Chicago

# Home Assistant long-lived access token (Settings > Security > Long-lived access tokens)
HA_LONG_LIVED_TOKEN=your-ha-long-lived-token-here
