# Unraid Management + Media + AI Stack - Environment Variables
# Used by: docker-compose.yml (management), media-stack.yml (DUMB AIO), ai-stack.yml (Ollama/WebUI)
# Copy to .env and fill in values before deploying.

# ─── System ────────────────────────────────────────────────────────────────

# Unraid container permissions (nobody:users on Unraid)
PUID=99
PGID=100

# Timezone (e.g. America/Chicago, America/New_York, Europe/London)
TZ=America/Chicago

# Base path for persistent container appdata on Unraid
APPDATA_PATH=/mnt/user/appdata

# ─── Management stack (docker-compose.yml) ─────────────────────────────────

# Tailscale auth key (generate at https://login.tailscale.com/admin/authkeys)
TAILSCALE_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXX

# Subnet to advertise via Tailscale exit node (e.g. your LAN CIDR)
LOCAL_SUBNET=192.168.1.0/24

# Home Assistant long-lived access token (Settings > Security > Long-lived access tokens)
HA_LONG_LIVED_TOKEN=your-ha-long-lived-token-here

# ─── DUMB AIO media stack (media-stack.yml) ────────────────────────────────

# Real-Debrid API key (https://real-debrid.com/apitoken)
REAL_DEBRID_API_KEY=your-real-debrid-api-key-here

# PostgreSQL credentials shared by Riven and Zilean
POSTGRES_USER=riven
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=riven

# Plex (optional — set PLEX_ENABLED=false to skip Plex integration in Riven)
PLEX_ENABLED=false
PLEX_CLAIM_TOKEN=claim-XXXXXXXXXXXXXXXX
PLEX_TOKEN=your-plex-token-here

# Media / storage paths
MEDIA_PATH=/mnt/user/DUMB

# ─── AI stack (ai-stack.yml) ───────────────────────────────────────────────

# Open WebUI session secret (run: openssl rand -hex 32)
WEBUI_SECRET_KEY=change-me-openssl-rand-hex-32

# LiteLLM gateway URL for Open WebUI on Unraid (override if your Node B IP differs)
LITELLM_GATEWAY_URL=http://192.168.1.222:4000/v1

# LiteLLM gateway API key (Node B at 192.168.1.222:4000 — must match node-b-litellm config)
LITELLM_API_KEY=your-litellm-api-key-here
