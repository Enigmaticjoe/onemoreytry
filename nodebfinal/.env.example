# Node B Final — Environment Template
# Node B (Unraid) at 192.168.1.222
#
# Copy this file to .env and fill in your values before deploying any stack.
#   cp .env.example .env
#
# NEVER commit your .env file — it contains secrets.
# The .gitignore in this directory excludes .env automatically.

# ─── Common settings ───────────────────────────────────────────────────────────
TZ=America/New_York
# Unraid default user/group for most linuxserver.io containers
PUID=99
PGID=100

# Paths — adjust to match your Unraid share layout
APPDATA_PATH=/mnt/user/appdata
# Media root (DUMB convention). Example children: tv, movies, music, torrents, usenet
MEDIA_PATH=/mnt/user/DUMB

# Node B LAN host/IP used by services that must advertise callback URLs
NODE_B_HOST=192.168.1.222

# Local network subnet for Tailscale exit-node advertisement
LOCAL_SUBNET=192.168.1.0/24

# ─── Tailscale ─────────────────────────────────────────────────────────────────
# Get auth key from: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=tskey-auth-your-key-here

# ─── Portainer BE ──────────────────────────────────────────────────────────────
# Only required if using Portainer Business Edition with a license
# PORTAINER_LICENSE_KEY=your-license-key

# ─── Homepage dashboard ────────────────────────────────────────────────────────
# Home Assistant long-lived access token (for HA widget on dashboard)
# Generate in HA → Profile → Long-Lived Access Tokens
# Used as HA_TOKEN in n8n workflows and HOMEPAGE_VAR_HA_TOKEN in Homepage.
HA_TOKEN=your-ha-token-here

# ─── Cloudflare Zero-Trust tunnel ──────────────────────────────────────────────
# Get token from: dash.cloudflare.com → Zero Trust → Access → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── Watchtower notifications ──────────────────────────────────────────────────
# Discord webhook URL for update notifications (optional)
# Format: discord://webhook-id/webhook-token
WATCHTOWER_DISCORD_URL=

# ─── VPN (Gluetun) ─────────────────────────────────────────────────────────────
# VPN provider: private internet access, mullvad, nordvpn, expressvpn, etc.
# Full provider list: https://github.com/qdm12/gluetun/wiki
VPN_SERVICE_PROVIDER=private internet access
VPN_USER=your-vpn-username
VPN_PASSWORD=your-vpn-password
VPN_REGIONS=US East

# ─── Plex ──────────────────────────────────────────────────────────────────────
# Claim token for first-time setup: https://www.plex.tv/claim/
# Leave empty after first successful startup.
PLEX_CLAIM_TOKEN=claim-your-token-here
PLEX_TOKEN=your-plex-token-here

# ─── Tautulli ──────────────────────────────────────────────────────────────────
# Get API key from: Tautulli → Settings → Web Interface → API key
TAUTULLI_API_KEY=your-tautulli-api-key

# ─── Media automation API keys ─────────────────────────────────────────────────
# Get from each service: Settings → General → API Key
SONARR_API_KEY=your-sonarr-api-key
RADARR_API_KEY=your-radarr-api-key
JELLYFIN_API_KEY=your-jellyfin-api-key

# ─── Browserless ───────────────────────────────────────────────────────────────
# Secret token for authenticating requests to browserless
# Generate: openssl rand -hex 32
BROWSERLESS_TOKEN=

# ─── LiteLLM Gateway ───────────────────────────────────────────────────────────
# Master API key for the LiteLLM proxy at http://192.168.1.222:4000/v1
# All AI clients (Home Assistant, Open WebUI, n8n) use this key.
# Generate: openssl rand -hex 32
# Example: sk-my-homelab-key-change-this
LITELLM_MASTER_KEY=

# ─── n8n ───────────────────────────────────────────────────────────────────────
# Admin credentials for the n8n web UI
N8N_USER=admin
# N8N_PASSWORD must be set — no default provided to enforce using a strong password.
# Generate: openssl rand -base64 24
N8N_PASSWORD=
N8N_HOST=192.168.1.222

# Discord webhook URL for n8n to send notifications
# Create at: Discord server → Channel Settings → Integrations → Webhooks
# Set this in n8n as an environment variable named DISCORD_WEBHOOK.
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your-webhook-here


# ─── Open WebUI / AI Orchestration ─────────────────────────────────────────────
# Strong random string: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=

# SearXNG secret key: openssl rand -hex 32
SEARXNG_SECRET_KEY=

# Embedding model for hf-tei-embed
TEI_MODEL_ID=BAAI/bge-small-en-v1.5

# ─── Nextcloud (optional cloud apps stack) ─────────────────────────────────────
NEXTCLOUD_DB_ROOT_PASSWORD=
NEXTCLOUD_DB_PASSWORD=

# ─── Recommendarr ──────────────────────────────────────────────────────────────
# Ollama model to use for recommendations (must be pulled first)
# docker exec ollama ollama pull qwen3:8b
RECOMMENDARR_MODEL=qwen3:8b

# ─── Voice pipeline (Wyoming Whisper + Piper) ───────────────────────────────────
# Whisper model size — small-int8 works well on CPU, no GPU needed
# Options: tiny-int8, base-int8, small-int8, medium-int8, large-v2-int8
WHISPER_MODEL=small-int8

# Piper TTS voice — full list: https://rhasspy.github.io/piper-samples/
# Options: en_US-lessac-medium, en_US-ryan-high, en_US-amy-medium
PIPER_VOICE=en_US-lessac-medium
