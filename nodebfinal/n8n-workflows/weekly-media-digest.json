{
  "name": "Weekly Media Digest",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 0 8 * * 0"
            }
          ]
        }
      },
      "id": "cron-sunday",
      "name": "Cron — Sunday 8am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://192.168.1.222:8181/api/v2",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.TAUTULLI_API_KEY }}"
            },
            {
              "name": "cmd",
              "value": "get_home_stats"
            },
            {
              "name": "time_range",
              "value": "7"
            }
          ]
        },
        "options": {}
      },
      "id": "tautulli-stats",
      "name": "Tautulli — Get Weekly Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.1.222:4000/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $env.LITELLM_MASTER_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"model\": \"brawn-fast\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a friendly media assistant. Keep responses under 200 words, conversational.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a weekly media watching digest based on these Tautulli statistics from the past 7 days. Include:\\n1. Total watch time summary\\n2. Most watched content\\n3. Any interesting patterns\\n4. A recommendation based on the watching habits\\n\\nStats: {{ JSON.stringify($node['Tautulli — Get Weekly Stats'].json.response.data) }}\"\n    }\n  ],\n  \"stream\": false\n}",
        "options": {}
      },
      "id": "litellm-digest",
      "name": "LiteLLM — Generate Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"username\": \"Node B Media Digest\",\n  \"embeds\": [\n    {\n      \"title\": \"📺 Weekly Media Digest\",\n      \"description\": \"{{ $node['LiteLLM — Generate Digest'].json.choices[0].message.content }}\",\n      \"color\": 3447003,\n      \"footer\": {\n        \"text\": \"Generated by Tautulli + LiteLLM on Node B\"\n      },\n      \"timestamp\": \"{{ new Date().toISOString() }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "discord-digest",
      "name": "Discord — Post Digest",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [900, 300]
    }
  ],
  "connections": {
    "Cron — Sunday 8am": {
      "main": [
        [
          {
            "node": "Tautulli — Get Weekly Stats",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Tautulli — Get Weekly Stats": {
      "main": [
        [
          {
            "node": "LiteLLM — Generate Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "LiteLLM — Generate Digest": {
      "main": [
        [
          {
            "node": "Discord — Post Digest",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "media",
      "createdAt": "2026-01-01T00:00:00.000Z",
      "updatedAt": "2026-01-01T00:00:00.000Z"
    },
    {
      "name": "ai",
      "createdAt": "2026-01-01T00:00:00.000Z",
      "updatedAt": "2026-01-01T00:00:00.000Z"
    }
  ],
  "meta": {
    "description": "Runs every Sunday at 8am. Pulls the last 7 days of watch stats from Tautulli, sends them to LiteLLM Gateway (brawn-fast / qwen3:8b) for a personalized digest, then posts the AI-generated summary to Discord.",
    "setup": "Set TAUTULLI_API_KEY, LITELLM_MASTER_KEY, and DISCORD_WEBHOOK in n8n environment variables or credentials."
  }
}

