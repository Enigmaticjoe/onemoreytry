{
  "name": "Smart Content Approval",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "overseerr-request",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-overseerr",
      "name": "Webhook — Overseerr Request",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "overseerr-new-request"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "http://192.168.1.222:8181/api/v2",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env.TAUTULLI_API_KEY }}"
            },
            {
              "name": "cmd",
              "value": "get_home_stats"
            },
            {
              "name": "time_range",
              "value": "30"
            }
          ]
        },
        "options": {}
      },
      "id": "tautulli-history",
      "name": "Tautulli — Get Watch History",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.1.222:11434/api/generate",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"model\": \"qwen3:8b\",\n  \"prompt\": \"You are helping decide whether to approve a media request for a home media server. Respond with ONLY a JSON object with keys: approve (boolean), reason (string, max 50 words), confidence (number 0-100).\\n\\nMedia requested:\\n- Title: {{ $node['Webhook — Overseerr Request'].json.subject }}\\n- Type: {{ $node['Webhook — Overseerr Request'].json.media.media_type }}\\n- Requested by: {{ $node['Webhook — Overseerr Request'].json.request.requestedBy_username }}\\n\\nRecent watch history (last 30 days): {{ JSON.stringify($node['Tautulli — Get Watch History'].json.response.data) }}\\n\\nApprove if it matches the existing taste profile. Reject only if it is wildly off-genre with low confidence.\",\n  \"stream\": false\n}",
        "options": {}
      },
      "id": "ollama-decision",
      "name": "Ollama — Evaluate Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = $node['Ollama — Evaluate Request'].json.response;\nconst match = raw.match(/\\{[\\s\\S]*\\}/);\nconst decision = match ? JSON.parse(match[0]) : { approve: true, reason: 'Parse error — defaulting to approve', confidence: 50 };\nreturn [{ json: decision }];"
      },
      "id": "parse-decision",
      "name": "Parse Ollama Decision",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.approve }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "route-decision",
      "name": "Approve or Hold?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1100, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://192.168.1.222:5055/api/v1/request/{{ $node['Webhook — Overseerr Request'].json.request.request_id }}/approve",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Api-Key",
              "value": "={{ $env.OVERSEERR_API_KEY }}"
            }
          ]
        },
        "options": {}
      },
      "id": "overseerr-approve",
      "name": "Overseerr — Auto Approve",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1320, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"username\": \"Node B Content Gatekeeper\",\n  \"embeds\": [\n    {\n      \"title\": \"✅ Request Auto-Approved: {{ $node['Webhook — Overseerr Request'].json.subject }}\",\n      \"description\": \"{{ $node['Parse Ollama Decision'].json.reason }}\",\n      \"color\": 65280,\n      \"footer\": {\n        \"text\": \"Confidence: {{ $node['Parse Ollama Decision'].json.confidence }}% — approved by Ollama\"\n      }\n    }\n  ]\n}",
        "options": {}
      },
      "id": "discord-approved",
      "name": "Discord — Notify Approved",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1540, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.DISCORD_WEBHOOK }}",
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"username\": \"Node B Content Gatekeeper\",\n  \"embeds\": [\n    {\n      \"title\": \"⏸️ Request Needs Review: {{ $node['Webhook — Overseerr Request'].json.subject }}\",\n      \"description\": \"**AI Analysis:** {{ $node['Parse Ollama Decision'].json.reason }}\\n\\n**Action needed:** Visit Overseerr to approve or deny: http://192.168.1.222:5055/requests\",\n      \"color\": 16776960,\n      \"footer\": {\n        \"text\": \"Confidence: {{ $node['Parse Ollama Decision'].json.confidence }}% — held for manual review\"\n      }\n    }\n  ]\n}",
        "options": {}
      },
      "id": "discord-hold",
      "name": "Discord — Notify Hold for Review",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1320, 400]
    }
  ],
  "connections": {
    "Webhook — Overseerr Request": {
      "main": [
        [
          {
            "node": "Tautulli — Get Watch History",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Tautulli — Get Watch History": {
      "main": [
        [
          {
            "node": "Ollama — Evaluate Request",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ollama — Evaluate Request": {
      "main": [
        [
          {
            "node": "Parse Ollama Decision",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Ollama Decision": {
      "main": [
        [
          {
            "node": "Approve or Hold?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Approve or Hold?": {
      "main": [
        [
          {
            "node": "Overseerr — Auto Approve",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Discord — Notify Hold for Review",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Overseerr — Auto Approve": {
      "main": [
        [
          {
            "node": "Discord — Notify Approved",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
