  ],
  "meta": {
    "description": "Receives Overseerr new-request webhooks. Checks 30-day Tautulli watch history, asks Ollama to evaluate if the request matches taste. Auto-approves good matches; holds questionable ones and pings Discord for manual review.",
    "setup": "In Overseerr: Settings → Notifications → Webhook → URL: http://192.168.1.222:5678/webhook/overseerr-request. Enable 'Request Pending Approval' event."
  }
}
