# OpenClaw — Node C environment file
# Copy to /opt/openclaw/.env and fill in your values.
#
# Usage:
#   docker compose -f node-c-arc/openclaw.yml --env-file /opt/openclaw/.env up -d

# ── Required ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
# Access UI:     http://<NODE_C_IP>:18789/?token=<this value>
OPENCLAW_GATEWAY_TOKEN=change-me-use-openssl-rand-hex-24

# ── Local Ollama on Node C ───────────────────────────────────────────────────
# Any non-empty value activates the Ollama provider.
# The baseUrl (host.docker.internal:11434) is set in openclaw.json.
OLLAMA_API_KEY=ollama

# ── LiteLLM Gateway on Node B (192.168.1.222:4000) ──────────────────────────
# Provides access to brain-heavy, brawn-fast and cloud model fallbacks.
LITELLM_API_KEY=sk-master-key

# ── KVM Operator on Node A — required for AI-driven KVM control ─────────────
KVM_OPERATOR_URL=http://192.168.1.9:5000
KVM_OPERATOR_TOKEN=change-me-use-openssl-rand-hex-24

# ── Home Assistant on Node D (optional) ─────────────────────────────────────
# HOME_ASSISTANT_URL=http://192.168.1.149:8123
# HOME_ASSISTANT_TOKEN=<HA long-lived access token>

# ── Cloud AI fallbacks (optional — all routed through LiteLLM above) ─────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...
# GROQ_API_KEY=...

# ── Messaging (optional) ────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=...
# DISCORD_BOT_TOKEN=...
