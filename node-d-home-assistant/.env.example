# Node D — Home Assistant environment variables
# Copy this file to .env and set real values before deploying.

# Timezone for the Home Assistant container
TZ=America/Chicago

# LiteLLM Gateway on Node B
LITELLM_BASE_URL=http://192.168.1.222:4000
LITELLM_API_KEY=sk-master-key

# Node A Brain fallback (optional)
NODE_A_BASE_URL=http://192.168.1.9:8000
