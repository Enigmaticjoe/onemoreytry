# Grand Unified AI Homelab — Portainer Deployment Guide
# ══════════════════════════════════════════════════════════════════════════════
#
#  PORTAINER-FIRST WORKFLOW (RECOMMENDED)
#
#  Step 1: Configure your nodes
#    cp config/node-inventory.env.example config/node-inventory.env
#    nano config/node-inventory.env      # set IPs and SSH users
#
#  Step 2: Run the SSH Auditor (diagnoses connectivity, maps hardware)
#    ./scripts/ssh-auditor.sh
#    ./scripts/ssh-auditor.sh --fix-firewall   # auto-open ports
#    ./scripts/ssh-auditor.sh --install-keys   # push SSH keys
#
#  Step 3: Install Portainer on all reachable nodes
#    ./scripts/portainer-install.sh
#    ./scripts/portainer-install.sh --status   # check existing installs
#
#  Step 4: Deploy application stacks
#    ./scripts/deploy-all.sh
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Node IPs ──────────────────────────────────────────────────────────────────
# Set these to the LAN IP addresses of each node.
# Leave as-is (with .X/.Y/.Z) for nodes you don't have — the scripts skip them.

NODE_A_IP=192.168.1.9         # Brain node (heavy LLM) — AMD RX 7900 XT
NODE_B_IP=192.168.1.222       # Unraid server — RTX 4070, LiteLLM gateway
NODE_C_IP=192.168.1.6         # Intel Arc node — vision AI (Ollama)
NODE_D_IP=192.168.1.149       # Home Assistant
NODE_E_IP=192.168.1.116       # Sentinel / NVR (Blue Iris)
PROXMOX_IP=192.168.1.174      # Proxmox hypervisor (optional)
KVM_IP=192.168.1.130          # NanoKVM IP for console access
KVM_HOSTNAME=kvm-d829.local   # mDNS name for KVM

# ── SSH Users ─────────────────────────────────────────────────────────────────
# The SSH user to connect as on each node.
# For Unraid: root  |  Ubuntu/Debian: ubuntu or your username  |  Pi: pi

NODE_A_SSH_USER=root
NODE_B_SSH_USER=root
NODE_C_SSH_USER=root
NODE_D_SSH_USER=root
NODE_E_SSH_USER=root

# ── Tailscale IPs (optional — fallback if LAN SSH fails) ─────────────────────
# If a node is not reachable via LAN SSH, the auditor tries Tailscale.
# Run `tailscale status` to find each node's 100.x.x.x address.
# Leave blank if you don't use Tailscale.

NODE_A_TS_IP=
NODE_B_TS_IP=
NODE_C_TS_IP=
NODE_D_TS_IP=
NODE_E_TS_IP=

# ── Service Ports ─────────────────────────────────────────────────────────────
# Defaults work for a standard homelab. Only change if you have port conflicts.

PORTAINER_PORT=9000           # Portainer web UI (HTTP)
PORTAINER_HTTPS_PORT=9443     # Portainer web UI (HTTPS)
PORTAINER_AGENT_PORT=8000     # Portainer agent tunnel
LITELLM_PORT=4000             # LiteLLM gateway
OLLAMA_PORT=11434             # Ollama API
OPENWEBUI_PORT=3000           # Open WebUI (Chimera Face)
NODE_A_DASHBOARD_PORT=3099    # Node A command center dashboard
KVM_OPERATOR_PORT=5000        # KVM Operator FastAPI
OPENCLAW_PORT=18789           # OpenClaw AI gateway
DEPLOY_GUI_PORT=9999          # Deploy GUI

# ── External Access ───────────────────────────────────────────────────────────
CLOUDFLARE_DOMAIN=happystrugglebus.us

# ── API Tokens ────────────────────────────────────────────────────────────────
# Generate these after Portainer is installed.
# Portainer token: Settings → Users → your user → Add API token
# LiteLLM key: set any string, used as the Bearer token for the proxy

LITELLM_API_KEY=sk-master-key
KVM_OPERATOR_TOKEN=
OPENCLAW_GATEWAY_TOKEN=
PORTAINER_TOKEN=              # ptr_xxxx... (from Portainer UI after install)
