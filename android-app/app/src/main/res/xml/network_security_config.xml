        <domain includeSubdomains="true">192.168.1.6</domain>
        <domain includeSubdomains="true">192.168.1.116</domain>
        <domain includeSubdomains="true">192.168.1.130</domain>
        <domain includeSubdomains="true">192.168.1.149</domain>
        <domain includeSubdomains="true">192.168.1.222</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
    </domain-config>
</network-security-config>
