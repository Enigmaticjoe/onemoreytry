# Grand Unified AI Home Lab — Node B Stack Environment Template
# Copy this file to .env and fill in the real values before running any stack.
#
#   cp stacks/.env.example stacks/.env
#
# NEVER commit your .env file — it contains secrets.

# ─── Common settings ───────────────────────────────────────────────────────────
TZ=America/New_York
PUID=1000
PGID=1000

# Paths — adjust to match your Unraid share layout
APPDATA_PATH=/mnt/user/appdata
MEDIA_PATH=/mnt/user/data

# ─── LiteLLM gateway ───────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-master-key

# ─── VPN (Gluetun) ─────────────────────────────────────────────────────────────
# VPN provider: private internet access, mullvad, nordvpn, expressvpn, etc.
VPN_SERVICE_PROVIDER=private internet access
VPN_USER=your-vpn-username
VPN_PASSWORD=your-vpn-password
VPN_REGIONS=US East

# ─── AI Orchestration stack ────────────────────────────────────────────────────
# SearXNG secret key — run: openssl rand -hex 32
SEARXNG_SECRET_KEY=change-me-please

# Browserless token (used by AI agents to authenticate)
BROWSERLESS_TOKEN=your-secret-token

# HuggingFace Text Embeddings Inference model
# Small, fast embedding model — no GPU required for this one
TEI_MODEL_ID=BAAI/bge-small-en-v1.5

# ─── vLLM stack ────────────────────────────────────────────────────────────────
# Model to load — must fit in 12 GB VRAM (RTX 4070)
# Examples: mistralai/Mistral-7B-Instruct-v0.3
#           NousResearch/Hermes-2-Pro-Mistral-7B
#           microsoft/Phi-3-mini-128k-instruct
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_MAX_CTX=8192
VLLM_GPU_MEM=0.90

# HuggingFace Hub token — required for gated models (Llama 3, Gemma, etc.)
# Get one at: https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# ─── Nextcloud stack ────────────────────────────────────────────────────────────
NEXTCLOUD_DB_ROOT_PASSWORD=changeme-root
NEXTCLOUD_DB_PASSWORD=changeme-nc

# ─── Tautulli ──────────────────────────────────────────────────────────────────
# Get API key from Tautulli → Settings → Web Interface → API key
TAUTULLI_API_KEY=your-tautulli-api-key

# ─── OpenClaw ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me

# ─── Cloudflare tunnel ─────────────────────────────────────────────────────────
# Get token from: dash.cloudflare.com → Zero Trust → Access → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── Riven stack (riven-stack.yml) ─────────────────────────────────────────────
# Riven is a Real-Debrid-powered VFS streaming engine that replaces the
# traditional *arr + torrent-client pipeline.

# PostgreSQL credentials for the Riven database — MUST be changed from defaults.
# DO NOT use the default postgres:postgres credentials in production.
# Generate a strong password with: openssl rand -base64 32
RIVEN_POSTGRES_USER=riven
RIVEN_POSTGRES_PASSWORD=CHANGE_ME_INSECURE
RIVEN_POSTGRES_DB=riven

# Real-Debrid API key — https://real-debrid.com/apitoken
RIVEN_REAL_DEBRID_API_KEY=your-real-debrid-api-key-here

# Riven backend API key (used by the frontend and any external clients).
# Generate with: openssl rand -hex 16
RIVEN_API_KEY=your-riven-api-key-here

# Auth secret for the Riven frontend session cookies.
# Generate with: openssl rand -base64 32
RIVEN_AUTH_SECRET=change-me-openssl-rand-base64-32

# URL you use to reach the Riven frontend in your browser.
# Change to your domain if using a reverse proxy.
RIVEN_ORIGIN=http://192.168.1.222:3001

# Host path for the Riven FUSE/VFS mount (must be pre-configured as rshared).
# The container always sees this library at /mount internally.
# See the Prerequisites section in riven-stack.yml for the mount setup commands.
RIVEN_MOUNT_PATH=/mnt/riven

# ── Jellyfin integration (default media server on Node B) ──────────────────────
# Set to true once Jellyfin is running and you have generated an API key.
# Jellyfin API key: Jellyfin → Dashboard → API Keys → +
RIVEN_JELLYFIN_ENABLED=true
RIVEN_JELLYFIN_URL=http://jellyfin:8096

# ── Plex integration (optional — leave disabled if using Jellyfin only) ─────────
RIVEN_PLEX_ENABLED=false
# Plex token for Riven ↔ Plex library sync.
# Get your token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# Generate a Plex claim token (first-time setup only): https://www.plex.tv/claim/
PLEX_TOKEN=your-plex-token-here
PLEX_CLAIM_TOKEN=claim-your-token-here

# ── Overseerr integration (optional) ────────────────────────────────────────────
# Enable only if Overseerr is running (media-stack.yml).
RIVEN_OVERSEERR_ENABLED=false
RIVEN_OVERSEERR_URL=http://overseerr:5055
RIVEN_OVERSEERR_API_KEY=

# ── Torrentio scraper ────────────────────────────────────────────────────────────
# Enabled by default — set to false to disable the Torrentio scraper.
RIVEN_TORRENTIO_ENABLED=true
